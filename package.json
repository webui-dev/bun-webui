{
  "name": "@webui-dev/bun-webui",
  "version": "2.5.5",
  "description": "Use any web browser as GUI, with Bun in the backend and HTML5 in the frontend.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "default": "./dist/mod.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gui",
    "ui",
    "webui",
    "browser",
    "webview"
  ],
  "author": "Hassan Draga",
  "license": "MIT",
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  }
}
